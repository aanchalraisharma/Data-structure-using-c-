#include <iostream>
using namespace std;

struct Node {
    int data;
    Node* next;
};

int main() {
    Node* head = nullptr;
    Node* temp;
    int n, value;

    cin >> n;

    for(int i = 0; i < n; i++) {
        cin >> value;

        Node* newNode = new Node();
        newNode->data = value;
        newNode->next = nullptr;

        if(head == nullptr) {
            head = newNode;
        } else {
            temp = head;
            while(temp->next != nullptr)
                temp = temp->next;
            temp->next = newNode;
        }
    }

    int sum = 0;

    Node* current = head;
    while(current != nullptr) {
        Node* prev = current;
        Node* ptr = current->next;

        while(ptr != nullptr) {
            if(ptr->data == current->data) {
                sum += ptr->data;
                prev->next = ptr->next;
                delete ptr;
                ptr = prev->next;
            } else {
                prev = ptr;
                ptr = ptr->next;
            }
        }
        current = current->next;
    }

    temp = head;
    while(temp != nullptr) {
        cout << temp->data << " ";
        temp = temp->next;
    }

    cout << endl << sum;

    return 0;
}
