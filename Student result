#include <iostream>
using namespace std;

class AcademicRecord {
protected:
    int marks;

public:
    void setMarks(int m) {
        marks = m;
    }
};

class SportsRecord {
protected:
    int score;

public:
    void setScore(int s) {
        score = s;
    }
};

class Student : public AcademicRecord, public SportsRecord {
public:
    void display() {
        cout << "Academic Marks: " << marks << endl;
        cout << "Sports Score: " << score << endl;
        cout << "Total Performance: " << marks + score << endl;
    }
};

int main() {
    Student s;
    s.setMarks(85);
    s.setScore(40);
    s.display();

    return 0;
}
