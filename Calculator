#include <iostream>
using namespace std;

class Calculator {
private:
    float a, b;

public:
    void setValues(float x, float y) {
        a = x;
        b = y;
    }

    float add() {
        return a + b;
    }

    float subtract() {
        return a - b;
    }

    float multiply() {
        return a * b;
    }

    float divide() {
        if (b != 0)
            return a / b;
        else {
            cout << "Division by zero not possible\n";
            return 0;
        }
    }
};

int main() {
    Calculator c;
    c.setValues(20, 5);

    cout << "Addition: " << c.add() << endl;
    cout << "Subtraction: " << c.subtract() << endl;
    cout << "Multiplication: " << c.multiply() << endl;
    cout << "Division: " << c.divide() << endl;

    return 0;
}
