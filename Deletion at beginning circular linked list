#include <iostream>
using namespace std;

struct Node {
    int data;
    Node* next;
};

Node* deleteAtBeginning(Node* head) {
    if (head == NULL) return NULL;

    if (head->next == head) {
        delete head;
        return NULL;
    }

    Node* last = head;
    while (last->next != head) {
        last = last->next;
    }

    Node* temp = head;
    head = head->next;
    last->next = head;

    delete temp;
    return head;
}

void display(Node* head) {
    if (head == NULL) return;

    Node* temp = head;
    do {
        cout << temp->data << " -> ";
        temp = temp->next;
    } while (temp != head);

    cout << "(back to head)" << endl;
}

int main() {
    Node* n1 = new Node{10, NULL};
    Node* n2 = new Node{20, NULL};
    Node* n3 = new Node{30, NULL};

    Node* head = n1;
    n1->next = n2;
    n2->next = n3;
    n3->next = head;

    display(head);

    head = deleteAtBeginning(head);

    display(head);

    return 0;
}
