#include <iostream>
using namespace std;

struct Node {
    int data;
    Node* next;
};

Node* deleteByValue(Node* head, int key) {
    if (head == NULL) return NULL;

    Node *curr = head, *prev = NULL;

    if (head->data == key) {
        if (head->next == head) {
            delete head;
            return NULL;
        }

        Node* last = head;
        while (last->next != head)
            last = last->next;

        head = head->next;
        last->next = head;
        delete curr;
        return head;
    }

    do {
        prev = curr;
        curr = curr->next;

        if (curr->data == key) {
            prev->next = curr->next;
            delete curr;
            return head;
        }

    } while (curr != head);

    return head;
}

void display(Node* head) {
    if (head == NULL) return;

    Node* temp = head;
    do {
        cout << temp->data << " -> ";
        temp = temp->next;
    } while (temp != head);

    cout << "(back to head)" << endl;
}

int main() {
    Node* head = NULL;

    Node* n1 = new Node{10, NULL};
    Node* n2 = new Node{20, NULL};
    Node* n3 = new Node{30, NULL};

    head = n1;
    n1->next = n2;
    n2->next = n3;
    n3->next = head;

    display(head);

    head = deleteByValue(head, 20);

    display(head);

    return 0;
}
