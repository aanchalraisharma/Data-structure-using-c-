#include <iostream>
using namespace std;

struct Node {
    int data;
    Node* next;
    Node* prev;
};

void cumulativeSum(Node* head) {
    int sum = 0;
    Node* temp = head;

    while (temp != NULL) {
        sum += temp->data;
        temp->data = sum;
        temp = temp->next;
    }
}

void display(Node* head) {
    Node* temp = head;

    while (temp != NULL) {
        cout << temp->data << " <-> ";
        temp = temp->next;
    }

    cout << "NULL" << endl;
}

int main() {
    Node* head = NULL;

    head = new Node{10, NULL, NULL};
    Node* n2 = new Node{20, NULL, NULL};
    Node* n3 = new Node{30, NULL, NULL};

    head->next = n2;
    n2->prev = head;
    n2->next = n3;
    n3->prev = n2;

    display(head);

    cumulativeSum(head);

    display(head);

    return 0;
}
