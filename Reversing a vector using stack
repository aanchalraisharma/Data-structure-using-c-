#include <iostream>
#include <vector>
#include <stack>
using namespace std;

void reverseVector(vector<int> &v) {
    stack<int> s;

    for (int i = 0; i < v.size(); i++) {
        s.push(v[i]);
    }

    for (int i = 0; i < v.size(); i++) {
        v[i] = s.top();
        s.pop();
    }
}

void display(vector<int> v) {
    for (int i = 0; i < v.size(); i++) {
        cout << v[i] << " ";
    }
    cout << endl;
}

int main() {
    vector<int> v;
    int n, x;

    cout << "Enter number of elements: ";
    cin >> n;

    cout << "Enter elements: ";
    for (int i = 0; i < n; i++) {
        cin >> x;
        v.push_back(x);
    }

    cout << "Original vector: ";
    display(v);

    reverseVector(v);

    cout << "Reversed vector: ";
    display(v);

    return 0;
}
