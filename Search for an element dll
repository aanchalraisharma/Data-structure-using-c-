#include <iostream>
using namespace std;

struct Node {
    int data;
    Node* next;
    Node* prev;
};

int search(Node* head, int key) {
    Node* temp = head;
    int pos = 1;

    while (temp != NULL) {
        if (temp->data == key)
            return pos;
        temp = temp->next;
        pos++;
    }

    return -1;
}

void display(Node* head) {
    Node* temp = head;

    while (temp != NULL) {
        cout << temp->data << " <-> ";
        temp = temp->next;
    }

    cout << "NULL" << endl;
}

int main() {
    Node* head = NULL;

    head = new Node{10, NULL, NULL};
    Node* n2 = new Node{20, NULL, NULL};
    Node* n3 = new Node{30, NULL, NULL};

    head->next = n2;
    n2->prev = head;
    n2->next = n3;
    n3->prev = n2;

    display(head);

    int pos = search(head, 20);

    if (pos != -1)
        cout << "Element found at position: " << pos << endl;
    else
        cout << "Element not found" << endl;

    return 0;
}
