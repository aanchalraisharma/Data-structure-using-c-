#include <iostream>
using namespace std;

struct Node {
    int data;
    Node* next;
};

Node* deleteFirstThree(Node* head) {
    int count = 0;

    while (head != NULL && count < 3) {
        Node* temp = head;
        head = head->next;
        delete temp;
        count++;
    }

    return head;
}

void display(Node* head) {
    Node* temp = head;

    while (temp != NULL) {
        cout << temp->data << " -> ";
        temp = temp->next;
    }

    cout << "NULL" << endl;
}

int main() {
    Node* head = new Node{10, NULL};
    Node* n2 = new Node{20, NULL};
    Node* n3 = new Node{30, NULL};
    Node* n4 = new Node{40, NULL};
    Node* n5 = new Node{50, NULL};

    head->next = n2;
    n2->next = n3;
    n3->next = n4;
    n4->next = n5;

    display(head);

    head = deleteFirstThree(head);

    display(head);

    return 0;
}
