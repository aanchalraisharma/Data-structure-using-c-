#include <iostream>
#include <vector>
using namespace std;

void reverseVector(vector<int> &v) {
    int start = 0;
    int end = v.size() - 1;

    while (start < end) {
        int temp = v[start];
        v[start] = v[end];
        v[end] = temp;

        start++;
        end--;
    }
}

void display(vector<int> v) {
    for (int i = 0; i < v.size(); i++) {
        cout << v[i] << " ";
    }
    cout << endl;
}

int main() {
    vector<int> v;
    int n, x;

    cout << "Enter number of elements: ";
    cin >> n;

    cout << "Enter elements: ";
    for (int i = 0; i < n; i++) {
        cin >> x;
        v.push_back(x);
    }

    cout << "Original vector: ";
    display(v);

    reverseVector(v);

    cout << "Reversed vector: ";
    display(v);

    return 0;
}
